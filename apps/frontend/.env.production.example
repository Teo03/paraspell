# Production-build env file for the frontend (Vite reads .env.production
# during `pnpm build`). Copy this to `.env.production` and adjust, OR set
# the same variable in the Vercel project's Environment Variables UI —
# Vercel injects those at build time and overrides this file's values.
#
# Required because src/App.tsx falls back to http://localhost:8000 when
# VITE_API_BASE_URL is unset, which is wrong for any deployed build.
VITE_API_BASE_URL=https://teo03-paraspell-backend.hf.space
