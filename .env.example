# =============================================================================
# ParaSpell environment configuration (SRS NFR-13).
# Defaults below are calibrated against Petrushevski & Zdraveski, "Accelerating
# Spell Checking with Parallel Processing Techniques" (ICAI'25). Override per
# deployment in your local .env (never commit .env).
# =============================================================================

# -----------------------------------------------------------------------------
# Backend — engine
# -----------------------------------------------------------------------------

# Hard cap on user uploads. Source: SRS NFR-02, NFR-08, UC-02. The 20 MB
# limit is the largest input the system is required to handle; anything bigger
# is rejected with HTTP 400 before any content is read.
MAX_UPLOAD_SIZE_MB=20

# Number of correction candidates returned per misspelled word.
# Source: SRS UC-03 and §5.2.4 — the popover shows "up to 5 ranked suggestions".
# Higher values give the user more options but the long tail rarely contains
# the right answer; lower values save bandwidth on long inputs.
MAX_SUGGESTIONS=5

# Number of parallel worker processes. Source: SRS FR-06, FR-07.
# `auto` resolves to os.cpu_count() at startup, which on most machines returns
# the SMT thread count (e.g. 16 on an 8-core / 16-thread CPU).
#
# Empirical scaling from the paper (Table II, average across 1–20 MB inputs):
#   1 worker  → 1.00x
#   2 workers → 1.96x
#   4 workers → 3.75x   (clears SRS NFR-03 minimum 3x)
#   8 workers → 6.38x   (≈ physical cores on the i9-9900K test rig)
#  16 workers → 7.01x   (≈ SMT threads — peak throughput)
#  20 workers → 7.03x   (plateau, diminishing returns)
#
# Memory cost: every worker loads the full 370k-word dictionary and Soundex
# map into its own process memory (~50–100 MB resident per worker on CPython
# 3.12). On RAM-constrained hosts (the SRS §6.3 minimum is 4 GB) cap this
# manually below cpu_count to avoid swapping — e.g. WORKER_COUNT=4.
WORKER_COUNT=auto

# Words per chunk handed to each worker. Source: SRS NFR-13 (configurable).
# `auto` splits the preprocessed word list evenly: ceil(total_words / workers),
# so each worker gets one balanced chunk and inter-process communication is
# minimal. The paper does not prescribe a specific chunk size — the Part 3
# benchmark task should validate this default and explore fixed-size chunking
# (e.g. 5000) if per-word cost turns out to be uneven.
CHUNK_SIZE=auto

# -----------------------------------------------------------------------------
# Backend — networking (NFR-11)
# -----------------------------------------------------------------------------

# Comma-separated list of origins permitted by the FastAPI CORS middleware.
# Add the deployed frontend URL alongside localhost for staging / production.
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Base URL the React app uses for API calls. In docker-compose the browser
# still hits localhost:8000 because requests originate from the host, not from
# inside the frontend container.
VITE_API_BASE_URL=http://localhost:8000
